{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$version": "1.2.0",
  "color": {
    "brand": {
      "primary": { "$type": "color", "$value": "#e03558" },
      "primary-hover": { "$type": "color", "$value": "#c82a4a" },
      "identity": { "$type": "color", "$value": "#6366f1" },
      "accent": { "$type": "color", "$value": "#7c3aed" },
      "signal": { "$type": "color", "$value": "#00e676" },
      "signal-text": { "$type": "color", "$value": "#0a8f4d" }
    },
    "neutral": {
      "0": { "$type": "color", "$value": "#ffffff" },
      "50": { "$type": "color", "$value": "#faf9f6" },
      "100": { "$type": "color", "$value": "#f5f2ec" },
      "200": { "$type": "color", "$value": "#f0ede8" },
      "300": { "$type": "color", "$value": "#d4cfe8" },
      "500": { "$type": "color", "$value": "#8c8c8c" },
      "700": { "$type": "color", "$value": "#555555" },
      "900": { "$type": "color", "$value": "#1a1a2e" }
    },
    "sepia": {
      "50": { "$type": "color", "$value": "#f0f0f0" },
      "300": { "$type": "color", "$value": "#a0a0a0" },
      "500": { "$type": "color", "$value": "#3d2215" },
      "600": { "$type": "color", "$value": "#25150e" },
      "700": { "$type": "color", "$value": "#1d0f09" },
      "800": { "$type": "color", "$value": "#170d08" },
      "900": { "$type": "color", "$value": "#0b0705" }
    },
    "semantic": {
      "background": { "$type": "color", "$value": "{color.neutral.50}" },
      "surface": { "$type": "color", "$value": "{color.neutral.200}" },
      "card": { "$type": "color", "$value": "{color.neutral.0}" },
      "card-sunken": { "$type": "color", "$value": "{color.neutral.100}" },
      "border": { "$type": "color", "$value": "{color.neutral.300}" },
      "ink": { "$type": "color", "$value": "{color.neutral.900}" },
      "ink-secondary": { "$type": "color", "$value": "{color.neutral.700}" },
      "muted": { "$type": "color", "$value": "{color.neutral.500}" },
      "focus": { "$type": "color", "$value": "{color.brand.identity}" },
      "success": { "$type": "color", "$value": "#15803d" },
      "warning": { "$type": "color", "$value": "#b45309" },
      "danger": { "$type": "color", "$value": "#991b1b" },
      "info": { "$type": "color", "$value": "#0369a1" }
    },
    "ui": {
      "sun": { "$type": "color", "$value": "#fbbf24" },
      "sun-soft": { "$type": "color", "$value": "#fcd34d" },
      "moon": { "$type": "color", "$value": "{color.brand.primary}" }
    },
    "domain": {
      "pc": { "$type": "color", "$value": "{color.brand.identity}" },
      "npc": { "$type": "color", "$value": "{color.semantic.warning}" },
      "available": { "$type": "color", "$value": "{color.brand.signal}" },
      "available-text": { "$type": "color", "$value": "{color.brand.signal-text}" },
      "remote": { "$type": "color", "$value": "{color.brand.accent}" },
      "claimed": { "$type": "color", "$value": "{color.semantic.info}" },
      "adopted": { "$type": "color", "$value": "{color.semantic.success}" },
      "forked": { "$type": "color", "$value": "{color.brand.accent}" },
      "oracle": { "$type": "color", "$value": "{color.brand.accent}" },
      "quoted": { "$type": "color", "$value": "{color.brand.primary}" }
    }
  },
  "font": {
    "family": {
      "sans": { "$type": "fontFamily", "$value": ["Inter", "-apple-system", "BlinkMacSystemFont", "sans-serif"] },
      "display": { "$type": "fontFamily", "$value": ["Fraunces", "Georgia", "serif"] },
      "mono": { "$type": "fontFamily", "$value": ["ui-monospace", "SFMono-Regular", "Menlo", "monospace"] }
    },
    "weight": {
      "regular": { "$type": "fontWeight", "$value": 400 },
      "medium": { "$type": "fontWeight", "$value": 500 },
      "semibold": { "$type": "fontWeight", "$value": 600 },
      "bold": { "$type": "fontWeight", "$value": 700 }
    },
    "size": {
      "overline": { "$type": "dimension", "$value": "0.6875rem" },
      "caption": { "$type": "dimension", "$value": "0.75rem" },
      "sm": { "$type": "dimension", "$value": "0.8125rem" },
      "base": { "$type": "dimension", "$value": "0.875rem" },
      "md": { "$type": "dimension", "$value": "0.9375rem" },
      "body": { "$type": "dimension", "$value": "1rem" },
      "lg": { "$type": "dimension", "$value": "1.0625rem" },
      "dialogue": { "$type": "dimension", "$value": "1.125rem" },
      "dialogue-read": { "$type": "dimension", "$value": "1.25rem" },
      "stat": { "$type": "dimension", "$value": "1.75rem" },
      "lede": { "$type": "dimension", "$value": "clamp(0.9375rem, 3.6cqi, 1.125rem)" },
      "h-sec": { "$type": "dimension", "$value": "clamp(1.125rem, 4.5cqi, 1.375rem)" },
      "h-page": { "$type": "dimension", "$value": "clamp(1.5rem, 6cqi, 1.875rem)" },
      "hero": { "$type": "dimension", "$value": "clamp(2rem, 9cqi, 3.125rem)" }
    },
    "lineHeight": {
      "none": { "$type": "number", "$value": 1 },
      "hero": { "$type": "number", "$value": 1.06 },
      "tight": { "$type": "number", "$value": 1.15 },
      "snug": { "$type": "number", "$value": 1.2 },
      "dialogue": { "$type": "number", "$value": 1.5 },
      "base": { "$type": "number", "$value": 1.55 },
      "relaxed": { "$type": "number", "$value": 1.7 },
      "loose": { "$type": "number", "$value": 1.8 },
      "castline": { "$type": "number", "$value": 2 }
    },
    "tracking": {
      "tight": { "$type": "dimension", "$value": "-0.02em" },
      "normal": { "$type": "dimension", "$value": "0" },
      "wide": { "$type": "dimension", "$value": "0.05em" },
      "wider": { "$type": "dimension", "$value": "0.08em" }
    }
  },
  "space": {
    "0": { "$type": "dimension", "$value": "0" },
    "2": { "$type": "dimension", "$value": "0.125rem" },
    "4": { "$type": "dimension", "$value": "0.25rem" },
    "6": { "$type": "dimension", "$value": "0.375rem" },
    "8": { "$type": "dimension", "$value": "0.5rem" },
    "10": { "$type": "dimension", "$value": "0.625rem" },
    "12": { "$type": "dimension", "$value": "0.75rem" },
    "14": { "$type": "dimension", "$value": "0.875rem" },
    "16": { "$type": "dimension", "$value": "1rem" },
    "18": { "$type": "dimension", "$value": "1.125rem" },
    "20": { "$type": "dimension", "$value": "1.25rem" },
    "22": { "$type": "dimension", "$value": "1.375rem" },
    "24": { "$type": "dimension", "$value": "1.5rem" },
    "28": { "$type": "dimension", "$value": "1.75rem" },
    "32": { "$type": "dimension", "$value": "2rem" },
    "40": { "$type": "dimension", "$value": "2.5rem" },
    "44": { "$type": "dimension", "$value": "2.75rem" },
    "56": { "$type": "dimension", "$value": "3.5rem" }
  },
  "radius": {
    "none": { "$type": "dimension", "$value": "0" },
    "xs": { "$type": "dimension", "$value": "0.25rem" },
    "sm": { "$type": "dimension", "$value": "0.375rem" },
    "md": { "$type": "dimension", "$value": "0.5rem" },
    "lg": { "$type": "dimension", "$value": "0.75rem" },
    "full": { "$type": "dimension", "$value": "999px" }
  },
  "shadow": {
    "card": {
      "$type": "shadow",
      "$value": { "offsetX": "0", "offsetY": "2px", "blur": "16px", "spread": "0", "color": "rgba(0,0,0,0.07)" }
    },
    "card-hover": {
      "$type": "shadow",
      "$value": { "offsetX": "0", "offsetY": "4px", "blur": "24px", "spread": "0", "color": "rgba(0,0,0,0.12)" }
    }
  },
  "border": {
    "width": {
      "hairline": { "$type": "dimension", "$value": "1px" },
      "ring": { "$type": "dimension", "$value": "1.5px" },
      "thick": { "$type": "dimension", "$value": "2px" },
      "heavy": { "$type": "dimension", "$value": "3px" }
    },
    "style": {
      "solid": { "$type": "strokeStyle", "$value": "solid" },
      "dashed": { "$type": "strokeStyle", "$value": "dashed" },
      "dotted": { "$type": "strokeStyle", "$value": "dotted" },
      "double": { "$type": "strokeStyle", "$value": "double" }
    }
  },
  "focus": {
    "width": { "$type": "dimension", "$value": "2px" },
    "offset": { "$type": "dimension", "$value": "2px" },
    "color": { "$type": "color", "$value": "{color.semantic.focus}" }
  },
  "motion": {
    "duration": {
      "instant": { "$type": "duration", "$value": "0ms" },
      "fast": { "$type": "duration", "$value": "150ms" },
      "base": { "$type": "duration", "$value": "200ms" },
      "slow": { "$type": "duration", "$value": "400ms" }
    },
    "easing": {
      "standard": { "$type": "cubicBezier", "$value": [0.4, 0, 0.2, 1] },
      "entrance": { "$type": "cubicBezier", "$value": [0.22, 1, 0.36, 1] }
    }
  },
  "breakpoint": {
    "xs": { "$type": "dimension", "$value": "480px" },
    "sm": { "$type": "dimension", "$value": "640px" },
    "md": { "$type": "dimension", "$value": "768px" },
    "lg": { "$type": "dimension", "$value": "1024px" },
    "xl": { "$type": "dimension", "$value": "1280px" }
  },
  "size": {
    "container": {
      "prose": { "$type": "dimension", "$value": "42rem" },
      "narrow": { "$type": "dimension", "$value": "48rem" },
      "mid": { "$type": "dimension", "$value": "64rem" },
      "wide": { "$type": "dimension", "$value": "80rem" }
    },
    "tap": { "$type": "dimension", "$value": "{space.44}" },
    "avatar": {
      "sm": { "$type": "dimension", "$value": "34px" },
      "md": { "$type": "dimension", "$value": "{space.44}" },
      "xl": { "$type": "dimension", "$value": "64px" }
    }
  },
  "icon": {
    "library": { "$type": "string", "$value": "lucide" },
    "style": { "$type": "string", "$value": "outline" },
    "sets": {
      "ui": { "$type": "string", "$value": "lucide" },
      "brand": { "$type": "string", "$value": "simple-icons" },
      "illustration": { "$type": "string", "$value": "game-icons" }
    },
    "size": {
      "sm": { "$type": "dimension", "$value": "{space.12}" },
      "md": { "$type": "dimension", "$value": "{space.16}" },
      "lg": { "$type": "dimension", "$value": "{space.24}" }
    },
    "stroke": {
      "default": { "$type": "dimension", "$value": "2px" }
    }
  },
  "zIndex": {
    "sticky": { "$type": "number", "$value": 40 },
    "header": { "$type": "number", "$value": 50 },
    "dropdown": { "$type": "number", "$value": 60 },
    "overlay": { "$type": "number", "$value": 80 },
    "modal": { "$type": "number", "$value": 100 },
    "toast": { "$type": "number", "$value": 120 }
  },
  "themes": {
    "dark": {
      "color": {
        "semantic": {
          "background": { "$value": "{color.sepia.900}" },
          "surface": { "$value": "{color.sepia.800}" },
          "card": { "$value": "{color.sepia.600}" },
          "card-sunken": { "$value": "{color.sepia.700}" },
          "border": { "$value": "{color.sepia.500}" },
          "ink": { "$value": "{color.sepia.50}" },
          "ink-secondary": { "$value": "{color.sepia.300}" },
          "muted": { "$value": "{color.sepia.300}" },
          "success": { "$value": "#4ade80" },
          "warning": { "$value": "#fbbf24" },
          "danger": { "$value": "#fca5a5" },
          "info": { "$value": "#7dd3fc" }
        },
        "brand": {
          "signal-text": { "$value": "{color.brand.signal}" }
        }
      },
      "shadow": {
        "card": {
          "$value": { "offsetX": "0", "offsetY": "0", "blur": "24px", "spread": "0", "color": "rgba(224,53,88,0.12)" }
        },
        "card-hover": {
          "$value": { "offsetX": "0", "offsetY": "0", "blur": "36px", "spread": "0", "color": "rgba(224,53,88,0.22)" }
        }
      }
    }
  }
}
